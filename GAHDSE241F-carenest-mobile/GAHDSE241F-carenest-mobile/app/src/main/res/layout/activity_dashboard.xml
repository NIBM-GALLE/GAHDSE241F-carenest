<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/dbbg1">

    <!-- Scrollable Content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="20dp"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Top Header with Back Button and Profile -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp">

                <ImageView
                    android:id="@+id/backIcon"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_alignParentStart="true"
                    android:layout_centerVertical="true"
                    android:src="@drawable/back"
                    android:contentDescription="@string/back_desc"
                    android:clickable="true"
                    android:focusable="true"
                    android:alpha="0.7" />

                <ImageView
                    android:id="@+id/profileImageView"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:src="@drawable/profile"
                    android:contentDescription="@string/profile_desc"
                    android:clickable="true"
                    android:focusable="true"
                    android:scaleType="centerCrop"
                    android:background="#E8F0FE"
                    android:padding="2dp"
                    app:cornerRadius="20dp" />

            </RelativeLayout>

            <!-- Welcome Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="24dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/welcome_to"
                    android:textSize="14sp"
                    android:textColor="#6B7280" />

                <TextView
                    android:id="@+id/welcomeTextView"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/carenest"
                    android:textSize="32sp"
                    android:textColor="#1E88E5"
                    android:textStyle="bold"
                    android:layout_marginTop="2dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/tagline"
                    android:textSize="13sp"
                    android:textColor="#9CA3AF"
                    android:layout_marginTop="6dp" />
            </LinearLayout>

            <!-- Categories Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/categories"
                    android:textSize="20sp"
                    android:textColor="#1F2937"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/view_all"
                    android:textSize="13sp"
                    android:textColor="#1E88E5"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Meal Plan Card - Soft Blue Background - M Size -->
            <androidx.cardview.widget.CardView
                android:id="@+id/MealPlanCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#E3F2FD"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="14dp"
                    android:gravity="center_vertical">

                    <!-- Small Image with Border -->
                    <LinearLayout
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:background="#FFFFFF"
                        app:cornerRadius="10dp"
                        android:padding="3dp">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:src="@drawable/img"
                            android:contentDescription="@string/meal_plan_img_desc"
                            android:scaleType="centerCrop"
                            app:cornerRadius="8dp" />
                    </LinearLayout>

                    <!-- Text Content -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/meal_plan"
                            android:textSize="16sp"
                            android:textColor="#1565C0"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/meal_plan_desc"
                            android:textSize="12sp"
                            android:textColor="#546E7A"
                            android:layout_marginTop="4dp"
                            android:maxLines="2" />
                    </LinearLayout>

                    <!-- Explore Button -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/explore"
                        android:textSize="13sp"
                        android:textColor="#1E88E5"
                        android:textStyle="bold" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Chat Card - Soft Purple Background - M Size -->
            <androidx.cardview.widget.CardView
                android:id="@+id/ChatCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#F3E5F5"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="14dp"
                    android:gravity="center_vertical">

                    <!-- Small Image with Border -->
                    <LinearLayout
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:background="#FFFFFF"
                        app:cornerRadius="10dp"
                        android:padding="3dp">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:src="@drawable/img_4"
                            android:contentDescription="@string/chat_img_desc"
                            android:scaleType="centerCrop"
                            app:cornerRadius="8dp" />
                    </LinearLayout>

                    <!-- Text Content -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/chat"
                            android:textSize="16sp"
                            android:textColor="#6A1B9A"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/chat_desc"
                            android:textSize="12sp"
                            android:textColor="#546E7A"
                            android:layout_marginTop="4dp"
                            android:maxLines="2" />
                    </LinearLayout>

                    <!-- Explore Button -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/explore"
                        android:textSize="13sp"
                        android:textColor="#9C27B0"
                        android:textStyle="bold" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Activities Card - Soft Orange Background - M Size -->
            <androidx.cardview.widget.CardView
                android:id="@+id/ActivityCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#FFF3E0"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="14dp"
                    android:gravity="center_vertical">

                    <!-- Small Image with Border -->
                    <LinearLayout
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:background="#FFFFFF"
                        app:cornerRadius="10dp"
                        android:padding="3dp">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:src="@drawable/img_2"
                            android:contentDescription="@string/activities_img_desc"
                            android:scaleType="centerCrop"
                            app:cornerRadius="8dp" />
                    </LinearLayout>

                    <!-- Text Content -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/activities"
                            android:textSize="16sp"
                            android:textColor="#E65100"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/activities_desc"
                            android:textSize="12sp"
                            android:textColor="#546E7A"
                            android:layout_marginTop="4dp"
                            android:maxLines="2" />
                    </LinearLayout>

                    <!-- Explore Button -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/explore"
                        android:textSize="13sp"
                        android:textColor="#FF9800"
                        android:textStyle="bold" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

    <!-- Bottom Navigation Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="65dp"
        android:orientation="horizontal"
        android:gravity="center"
        android:background="#FFFFFF"
        android:elevation="10dp"
        android:baselineAligned="false">

        <!-- Home -->
        <LinearLayout
            android:id="@+id/bottomNavHome"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_home"
                android:contentDescription="@string/home"
                app:tint="#1E88E5" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/home"
                android:textSize="11sp"
                android:textColor="#1E88E5"
                android:layout_marginTop="4dp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Meal Plan -->
        <LinearLayout
            android:id="@+id/bottomNavMealPlan"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_meal_plan"
                android:contentDescription="@string/meal_plan"
                app:tint="#9CA3AF" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/meal_plan"
                android:textSize="11sp"
                android:textColor="#9CA3AF"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <!-- Chat -->
        <LinearLayout
            android:id="@+id/bottomNavChat"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_chat"
                android:contentDescription="@string/chat"
                app:tint="#9CA3AF" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/chat"
                android:textSize="11sp"
                android:textColor="#9CA3AF"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <!-- Activities -->
        <LinearLayout
            android:id="@+id/bottomNavActivities"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_activities"
                android:contentDescription="@string/activities"
                app:tint="#9CA3AF" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/activities"
                android:textSize="11sp"
                android:textColor="#9CA3AF"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <!-- Profile -->
        <LinearLayout
            android:id="@+id/bottomNavProfile"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_profile"
                android:contentDescription="@string/profile"
                app:tint="#9CA3AF" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/profile"
                android:textSize="11sp"
                android:textColor="#9CA3AF"
                android:layout_marginTop="4dp" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>