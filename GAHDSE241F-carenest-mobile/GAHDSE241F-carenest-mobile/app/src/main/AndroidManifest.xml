<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Internet permission for API calls -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.DaycareApp"
        android:usesCleartextTraffic="true"
        tools:targetApi="31">

        <!-- Landing Page Activity (LAUNCHER - First screen) -->
        <activity
            android:name=".LandingPageActivity"
            android:exported="true"
            android:label="LittleStars Daycare">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Login Page Activity -->
        <activity
            android:name=".LoginActivity"
            android:exported="false"
            android:label="Login" />

        <!-- Dashboard Page Activity -->
        <activity
            android:name=".DashboardActivity"
            android:exported="false"
            android:label="Dashboard" />

        <!-- Chat Page Activity -->
        <activity
            android:name=".ChatActivity"
            android:exported="false"
            android:label="Messages" />

        <!-- Meal Plan Page -->
        <activity
            android:name=".MealPlanActivity"
            android:exported="false"
            android:label="Meal Plan" />

        <!-- Profile Page Activity -->
        <activity
            android:name=".ProfileActivity"
            android:exported="false"
            android:label="Profile" />

        <activity
            android:name=".ActivityPageActivity"
            android:exported="false"
            android:label="Activities" />

    </application>

</manifest>