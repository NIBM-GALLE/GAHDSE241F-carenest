<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:padding="25dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Top Header Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/backIcon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="16dp"
                android:clickable="true"
                android:contentDescription="Back"
                android:focusable="true"
                android:src="@drawable/back" />
        </LinearLayout>

        <!-- Logout (Top Right) -->
        <TextView
            android:id="@+id/tv_logout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Logout"
            android:textColor="@color/dark_blue"
            android:textStyle="bold"
            android:textSize="16sp"
            android:layout_gravity="end"
            android:layout_marginTop="8dp" />

        <!-- Profile Image + Camera Icon -->
        <RelativeLayout
            android:id="@+id/profileImageContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp">

            <ImageView
                android:id="@+id/profileImage"
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:layout_centerInParent="true"
                android:src="@drawable/profile"
                android:scaleType="centerCrop"
                android:background="@drawable/circle_background" />


            <ImageView
                android:id="@+id/camera"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginStart="16dp"
                android:src="@drawable/cam"
                android:layout_alignBottom="@id/profileImage"
                android:layout_alignEnd="@id/profileImage"
                android:layout_marginBottom="4dp"
                android:layout_marginEnd="4dp"
                android:padding="4dp"
                android:contentDescription="change_profile_cam"
                android:clickable="true"
                android:focusable="true" />

        </RelativeLayout>

        <!-- Name -->
        <TextView
            android:id="@+id/profileName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Hirushi Peiris"
            android:textAlignment="center"
            android:textStyle="bold"
            android:textSize="18sp"
            android:layout_marginTop="12dp" />

        <!-- About Child Section -->
        <LinearLayout
            android:id="@+id/aboutChildSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="25dp"
            android:orientation="vertical">

            <TextView
                android:text=" About Child"
                android:textStyle="bold"
                android:textSize="16sp"
                android:layout_marginBottom="8dp"
                android:layout_height="wrap_content"
                android:layout_width="match_parent"/>

            <TextView
                android:id="@+id/tv_fullName"
                android:text="Full Name: Kalugama Hirushi Peiris"
                android:layout_height="wrap_content"
                android:layout_width="match_parent"/>
            <TextView
                android:id="@+id/tv_age"
                android:text="Age: 5"
                android:layout_height="wrap_content"
                android:layout_width="match_parent"/>
            <TextView
                android:id="@+id/tv_gender"
                android:text="Gender: Female"
                android:layout_height="wrap_content"
                android:layout_width="match_parent"/>
        </LinearLayout>

        <!-- Parent Contact Info Section -->
        <LinearLayout
            android:id="@+id/parentContactSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="25dp"
            android:orientation="vertical">

            <TextView
                android:text=" Parent Contact Info"
                android:textStyle="bold"
                android:textSize="16sp"
                android:layout_marginBottom="8dp"
                android:layout_height="wrap_content"
                android:layout_width="match_parent"/>

            <TextView
                android:id="@+id/tv_phone"
                android:text=" 09122594388"
                android:layout_height="wrap_content"
                android:layout_width="match_parent"/>
            <TextView
                android:id="@+id/tv_email"
                android:text=" hirushi@gmail.com"
                android:layout_height="wrap_content"
                android:layout_width="match_parent"/>
            <TextView
                android:id="@+id/tv_address"
                android:text="Galle, Sri Lanka."
                android:layout_height="wrap_content"
                android:layout_width="match_parent"/>
        </LinearLayout>

        <!-- Edit Profile Button -->
        <Button
            android:id="@+id/btn_edit_profile"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Edit Profile"
            android:layout_marginTop="32dp"
            android:layout_marginBottom="24dp"
            android:backgroundTint="@color/dark_blue"
            android:textColor="@android:color/white" />

    </LinearLayout>
</ScrollView>
